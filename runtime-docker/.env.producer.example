# Harbor / OCI repository for producer publish
HARBOR_DOMAIN=harbor.example.coop
DATASET_REPOSITORY=harbor.example.com/erp/datasets

# Optional tags/metadata
DATASET_TAG=latest
# DATE_TAG=20260519
ODOO_VERSION='OpenERP 5'

# Prewarmed image output (required for runtime-build-prewarmed)
# Use repository without tag; script publishes :latest and :YYYYMMDD
TARGET_IMAGE_REPOSITORY=harbor.example.com/erp/openerp
# Backward compatible alternative (tag is ignored for publish; repo part is used)
# TARGET_IMAGE=harbor.example.com/erp/openerp:custom-tag
# GITHUB_TOKEN=<github_token_with_repo_read_access>

# Reuse DB from runtime-build-prewarmed in dataset-producer-create
USE_PREWARMED_DB=1
EXPORT_PREWARMED_DB=1
PREWARMED_DB_DUMP_PATH=runtime-docker/build/prewarmed/prewarmed-db.dump.zst
# Bootstrap timeout for prewarm/export flows (seconds)
WAIT_TIMEOUT_SECONDS=1800

# Optional DB/compose overrides
# COMPOSE_FILE=/abs/path/to/docker-compose.yaml
# DB_SERVICE=db
# POSTGRES_DB=erp
# POSTGRES_USER=erp

# Optional strictness
EXPECTED_POSTGRES_MAJOR=13
