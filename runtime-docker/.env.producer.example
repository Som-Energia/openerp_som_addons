# Harbor / OCI repository for producer publish
DATASET_REPOSITORY=harbor.example.com/erp/datasets

# Optional tags/metadata
DATASET_TAG=latest
ODOO_VERSION=OpenERP 5

# Optional DB/compose overrides
# COMPOSE_FILE=/abs/path/to/docker-compose.yaml
# DB_SERVICE=db
# POSTGRES_DB=erp
# POSTGRES_USER=erp

# Optional strictness
EXPECTED_POSTGRES_MAJOR=13
