# Harbor (required for dataset pull)
HARBOR_DOMAIN=harbor.example.com
HARBOR_USERNAME=<user>
HARBOR_PASSWORD=<password_or_token>

# OCI refs
# Recomanat: tag prewarmed (evita clonat/bootstrap al primer arrencat)
ERP_RUNTIME_IMAGE=harbor.example.com/erp/openerp:20260514-prewarmed
# Opcional en mode consumidor (si uses entrypoint bypass, no cal per arrencar)
GITHUB_TOKEN=
DATASET_REPOSITORY=harbor.example.com/erp/datasets
DATASET_TAG=latest

# Local runtime DB credentials
POSTGRES_USER=erp
POSTGRES_PASSWORD=erp
POSTGRES_DB=erp

# Post-restore credentials (evita usuaris sense password)
RESET_ADMIN_LOGIN=admin
RESET_ADMIN_PASSWORD=admin

# ERP web port
ERP_XMLRPC_PORT=8069
