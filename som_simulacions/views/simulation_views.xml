<?xml version="1.0" encoding="utf-8"?>
<openerp>
    <data>
        <record id="view_simulacio_request_tree" model="ir.ui.view">
            <field name="name">som.simulacio.request.tree</field>
            <field name="model">som.simulacio.request</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Indexed simulations">
                    <field name="name"/>
                    <field name="year"/>
                    <field name="month"/>
                    <field name="tariff_code"/>
                    <field name="power_p1"/>
                    <field name="power_p2"/>
                    <field name="power_p3"/>
                </tree>
            </field>
        </record>

        <record id="view_simulacio_request_form" model="ir.ui.view">
            <field name="name">som.simulacio.request.form</field>
            <field name="model">som.simulacio.request</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Indexed simulation request">
                    <group col="4">
                        <field name="name"/>
                        <field name="year"/>
                        <field name="month"/>
                        <field name="tariff_code"/>
                        <field name="power_p1"/>
                        <field name="power_p2"/>
                        <field name="power_p3"/>
                    </group>
                    <button name="compute_indexed_estimate" string="Run estimate" type="object"/>
                </form>
            </field>
        </record>

        <record id="view_simulacio_result_tree" model="ir.ui.view">
            <field name="name">som.simulacio.result.tree</field>
            <field name="model">som.simulacio.result</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="Indexed simulation results">
                    <field name="name"/>
                    <field name="request_id"/>
                    <field name="untaxed_total" readonly="1"/>
                    <field name="selected_energy_price_id" readonly="1"/>
                    <field name="selected_coeff_set_id" readonly="1"/>
                </tree>
            </field>
        </record>

        <record id="view_simulacio_result_form" model="ir.ui.view">
            <field name="name">som.simulacio.result.form</field>
            <field name="model">som.simulacio.result</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Indexed simulation result">
                    <group col="4">
                        <field name="name" readonly="1"/>
                        <field name="request_id" readonly="1"/>
                        <field name="untaxed_total" readonly="1"/>
                        <field name="selected_energy_price_id" readonly="1"/>
                        <field name="selected_coeff_set_id" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Traceability">
                            <field name="fallback_flags" readonly="1" colspan="4"/>
                            <field name="traceability_payload" readonly="1" colspan="4"/>
                        </page>
                        <page string="Lines">
                            <field name="line_ids" readonly="1" nolabel="1" colspan="4"/>
                        </page>
                    </notebook>
                </form>
            </field>
        </record>
    </data>
</openerp>
